# Penpot master key. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
PENPOT_SECRET_KEY=change-this-insecure-key

# Public URL Penpot is served at. The frontend bakes this into every API/asset
# call, so it must match the URL you browse. Temporarily http://localhost:9001 for
# direct access; switch to http://penpot.homelab once that resolves via Pi-hole DNS.
PENPOT_PUBLIC_URI=http://localhost:9001
